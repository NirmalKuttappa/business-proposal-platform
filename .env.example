# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# See README.md for step-by-step instructions on getting each one.
# ─────────────────────────────────────────────────────────────

# Public site URL — http://localhost:3000 locally, your Netlify URL in prod
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Stripe — dashboard.stripe.com → Developers → API keys (use test keys)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Stripe webhook signing secret — Developers → Webhooks (or `stripe listen`)
STRIPE_WEBHOOK_SECRET=

# Resend — resend.com → API Keys (email notifications; optional)
RESEND_API_KEY=
# From-address for notification emails. resend.com's shared sender works for
# testing; use a verified domain address in production.
RESEND_FROM_EMAIL=onboarding@resend.dev

# ── Booking (Google Calendar appointment scheduling) ────────
# Your public Google Calendar Appointment Scheduling page URL — clients
# book a call through it. Create one in Google Calendar (Create →
# Appointment schedule), then paste its share link here. Leave blank to
# hide the "Book a call" buttons.
NEXT_PUBLIC_BOOKING_URL=
